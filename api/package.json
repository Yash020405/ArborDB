{
  "name": "arbordb-api",
  "version": "1.0.0",
  "description": "ArborDB Query Layer + Backend API — SQL parsing, execution, file uploads, and metrics",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "jest --verbose --forceExit --detectOpenHandles",
    "test:coverage": "jest --coverage --forceExit --detectOpenHandles",
    "benchmark:index": "node scripts/benchmark-index-vs-non-index.js",
    "lint": "eslint --config eslint.config.js \"src/**/*.js\" \"tests/**/*.js\"",
    "lint:fix": "eslint --config eslint.config.js \"src/**/*.js\" \"tests/**/*.js\" --fix"
  },
  "keywords": [
    "database",
    "sql",
    "parser",
    "bplus-tree",
    "storage-engine"
  ],
  "author": "ArborDB Team",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "joi": "^17.13.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "papaparse": "^5.4.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js"
    ]
  }
}
